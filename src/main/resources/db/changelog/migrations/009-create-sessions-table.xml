<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="9" author="deniskoriavets">
        <createTable tableName="sessions">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="group_id" type="UUID">
                <constraints nullable="false"
                             foreignKeyName="fk_sessions_group"
                             referencedTableName="groups"
                             referencedColumnNames="id"/>
            </column>
            <column name="schedule_id" type="UUID">
                <constraints foreignKeyName="fk_sessions_schedule"
                             referencedTableName="schedules"
                             referencedColumnNames="id"/>
            </column>
            <column name="date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="start_time" type="TIME">
                <constraints nullable="false"/>
            </column>
            <column name="end_time" type="TIME">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="cancel_reason" type="VARCHAR(255)"/>
            <column name="is_deleted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="sessions" indexName="idx_sessions_group_id">
            <column name="group_id"/>
        </createIndex>
        <createIndex tableName="sessions" indexName="idx_sessions_date">
            <column name="date"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>