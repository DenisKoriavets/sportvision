<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="12" author="deniskoriavets">
        <createTable tableName="subscriptions">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="child_id" type="UUID">
                <constraints nullable="false"
                             foreignKeyName="fk_subscriptions_child"
                             referencedTableName="children"
                             referencedColumnNames="id"/>
            </column>
            <column name="plan_id" type="UUID">
                <constraints nullable="false"
                             foreignKeyName="fk_subscriptions_plan"
                             referencedTableName="subscription_plans"
                             referencedColumnNames="id"/>
            </column>
            <column name="total_sessions" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="remaining_sessions" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="start_date" type="DATE"/>
            <column name="end_date" type="DATE"/>
            <column name="version" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="is_deleted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="subscriptions" indexName="idx_subscriptions_child_id">
            <column name="child_id"/>
        </createIndex>
        <createIndex tableName="subscriptions" indexName="idx_subscriptions_status">
            <column name="status"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>