<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="10" author="deniskoriavets">
        <createTable tableName="attendances">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="session_id" type="UUID">
                <constraints nullable="false"
                             foreignKeyName="fk_attendances_session"
                             referencedTableName="sessions"
                             referencedColumnNames="id"/>
            </column>
            <column name="child_id" type="UUID">
                <constraints nullable="false"
                             foreignKeyName="fk_attendances_child"
                             referencedTableName="children"
                             referencedColumnNames="id"/>
            </column>
            <column name="status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="marked_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="marked_by_coach_id" type="UUID">
                <constraints nullable="false"
                             foreignKeyName="fk_attendances_coach"
                             referencedTableName="parents"
                             referencedColumnNames="id"/>
            </column>
        </createTable>

        <addUniqueConstraint tableName="attendances"
                             columnNames="session_id, child_id"
                             constraintName="uk_attendances_session_child"/>

        <createIndex tableName="attendances" indexName="idx_attendances_session_id">
            <column name="session_id"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>